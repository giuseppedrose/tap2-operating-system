# Tap2 OS — Environment Variables
# Copy to .env.local and fill in your values.
# cp .env.example .env.local

# ─── Public (safe for client-side) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ─── Admin access ───────────────────────────────────────────────────────────
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password

# ─── Server-side only — never use NEXT_PUBLIC_ prefix below ─────────────────

# Supabase service role (admin writes — server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (revenue truth)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# HubSpot (pipeline truth)
HUBSPOT_ACCESS_TOKEN=your-hubspot-access-token

# Instantly AI (outbound campaigns)
INSTANTLY_API_KEY=your-instantly-api-key

# Google Calendar / Gmail (OAuth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.vercel.app/api/auth/google/callback

# Fathom (meeting intelligence)
FATHOM_API_KEY=your-fathom-api-key

# Anthropic (AI analysis layer)
ANTHROPIC_API_KEY=your-anthropic-api-key
