# =============================================================
# Tap2 OS — Environment Variables Reference
# =============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git (.gitignore covers it).
#
# cp .env.local.example .env.local
#
# SECURITY RULES:
# - Never prefix secret keys with NEXT_PUBLIC_
# - Never log, print, or commit real API keys
# - Rotate any key that is accidentally exposed
# - Production keys live in Vercel Dashboard → Settings → Environment Variables
# =============================================================

# -------------------------------------------------------------
# PUBLIC — safe for client-side (only these two)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -------------------------------------------------------------
# SERVER-SIDE ONLY — never use NEXT_PUBLIC_ prefix below
# -------------------------------------------------------------

# Supabase service role key (admin access — server only)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — Revenue Intelligence
# Status: Pending — connect to make MRR/ARR live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# HubSpot — Sales Pipeline
# Status: Pending — connect to make pipeline data live
HUBSPOT_ACCESS_TOKEN=

# Instantly AI — Outbound Campaigns
# Status: Pending — connect to make campaign metrics live
INSTANTLY_API_KEY=

# Google Calendar + Gmail — Meetings & Invoice Scanning
# Status: Pending — OAuth flow required
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Fathom — Meeting Transcripts & Objection Analysis
# Status: Pending — connect to make meeting intelligence live
FATHOM_API_KEY=

# Anthropic (Claude API) — AI Insights Layer
# Status: Pending — server-side only, never expose in client code
ANTHROPIC_API_KEY=

# NOTE: Rabobank uses manual CSV upload — no API key required.
# Upload CSVs via the Cash & Runway page when that feature is built.
